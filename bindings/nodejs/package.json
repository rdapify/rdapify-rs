{
  "name": "@rdapify/core",
  "version": "0.1.0",
  "description": "Native Node.js binding for rdapify — powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "rdapify.*.node"
  ],
  "napi": {
    "name": "rdapify",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi build --platform --release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rdapify/rdapify-rs"
  },
  "keywords": [
    "rdap",
    "whois",
    "domain",
    "ip",
    "asn",
    "rust",
    "native"
  ]
}
